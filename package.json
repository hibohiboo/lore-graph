{
  "name": "lore-graph",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.5.2",
    "npm-check-updates": "^20.0.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "init": "git config --local core.hooksPath .githooks && echo Changed hooks directory when npm install",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "ncu": "turbo ncu --force && ncu -u",
    "graphdb": "bash ./docker/neo4j/bin/up.sh",
    "ollama": "bash ./docker/ollama/bin/up.sh",
    "check-types": "turbo run check-types"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ]
  }
}
